<Window x:Class="PixelLab.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PixelLab - Multimedia Processing" Height="768" Width="1024"
        WindowStartupLocation="CenterScreen" Background="#F0F0F0">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="350" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" CornerRadius="8" Margin="0,0,10,0">
            <TabControl Margin="5" BorderThickness="0">

                <TabItem Header="2D Image View">
                    <Grid AllowDrop="True" Drop="ImageArea_Drop" Background="#FAFAFA">
                        <TextBlock x:Name="PlaceholderText" 
                                   Text="Drag and drop image here" 
                                   FontSize="24" Foreground="#BBBBBB"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" 
                                   IsHitTestVisible="False"/>
                        <Image x:Name="MainImage" Stretch="Uniform" Margin="10"/>
                    </Grid>
                </TabItem>

                <TabItem Header="3D Color Space">
                    <Grid Background="#222222" MouseWheel="MainViewport3D_MouseWheel">

                        <Viewport3D x:Name="MainViewport3D" MouseLeftButtonDown="MainViewport3D_MouseLeftButtonDown">
                            <Viewport3D.Camera>
                                <PerspectiveCamera x:Name="Camera3D" 
                                                   Position="2.5,1.5,2.5" 
                                                   LookDirection="-2,-1,-2" 
                                                   UpDirection="0,1,0" 
                                                   FieldOfView="60"/>
                            </Viewport3D.Camera>

                            <ModelVisual3D>
                                <ModelVisual3D.Content>
                                    <Model3DGroup x:Name="ModelGroup3D">
                                        <AmbientLight Color="#555555"/>
                                        <DirectionalLight Color="#FFFFFF" Direction="-1,-1,-1"/>
                                        <DirectionalLight Color="#AAAAAA" Direction="1,1,1"/>
                                    </Model3DGroup>
                                </ModelVisual3D.Content>
                            </ModelVisual3D>
                        </Viewport3D>

                        <Border HorizontalAlignment="Left" VerticalAlignment="Top" Margin="15" Background="#AA000000" Padding="10">
                            <StackPanel>
                                <Button Content="Generate 3D Cube" Width="130" Height="30" Click="Generate3D_Click"/>
                                <TextBlock Text="Rotate Camera" Foreground="White" Margin="0,15,0,5" HorizontalAlignment="Center"/>
                                <Slider x:Name="SldCameraAngle" Minimum="0" Maximum="360" Value="45" Width="130" ValueChanged="CameraSlider_ValueChanged"/>
                                <TextBlock Text="Tip: Scroll to Zoom, Click to Pick Color" Foreground="#AAAAAA" FontSize="10" Margin="0,15,0,0" TextWrapping="Wrap" Width="120" TextAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Border x:Name="ColorInfoPanel" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="15" Background="#DD000000" Padding="15" CornerRadius="8" Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="Selected Color" Foreground="White" FontWeight="Bold" Margin="0,0,0,10" HorizontalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <Border x:Name="PickedColorSwatch" Width="40" Height="40" Background="Red" BorderBrush="White" BorderThickness="1" Margin="0,0,10,0"/>
                                    <TextBlock x:Name="TxtPickedHex" Text="#FF0000" Foreground="#CCCCCC" VerticalAlignment="Center" FontFamily="Consolas" FontSize="16"/>
                                </StackPanel>
                                <TextBlock x:Name="TxtPickedRGB" Text="RGB: (255, 0, 0)" Foreground="White" FontFamily="Consolas" Margin="0,2"/>
                                <TextBlock x:Name="TxtPickedHSV" Text="HSV: (0, 0%, 0%)" Foreground="White" FontFamily="Consolas" Margin="0,2"/>
                                <TextBlock x:Name="TxtPickedLAB" Text="LAB: (0, 0, 0)" Foreground="White" FontFamily="Consolas" Margin="0,2"/>
                                <TextBlock x:Name="TxtPickedCMYK" Text="CMYK: (0%, 0%, 0%, 0%)" Foreground="White" FontFamily="Consolas" Margin="0,2"/>
                            </StackPanel>
                        </Border>

                    </Grid>
                </TabItem>
            </TabControl>
        </Border>

        <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="15">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Control Panel" FontSize="22" FontWeight="Bold" Margin="0,0,0,15" HorizontalAlignment="Center"/>

                    <GroupBox Header="Image Information" Margin="0,0,0,15" Padding="5">
                        <StackPanel>
                            <TextBlock x:Name="LblImageName" Text="Name: -" Margin="0,2"/>
                            <TextBlock x:Name="LblImageFormat" Text="Format: -" Margin="0,2"/>
                            <TextBlock x:Name="LblImageSize" Text="Size: -" Margin="0,2"/>
                        </StackPanel>
                    </GroupBox>

                    <TextBlock Text="Color System:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <ComboBox x:Name="CmbColorSystem" Margin="0,0,0,15" SelectionChanged="CmbColorSystem_SelectionChanged">
                        <ComboBoxItem Content="RGB" IsSelected="True"/>
                        <ComboBoxItem Content="CMYK"/>
                        <ComboBoxItem Content="HSV"/>
                        <ComboBoxItem Content="YUV"/>
                        <ComboBoxItem Content="LAB"/>
                        <ComboBoxItem Content="YCbCr"/>
                    </ComboBox>

                    <GroupBox Header="Color Channels" Margin="0,0,0,15" Padding="5">
                        <StackPanel x:Name="ChannelsPanel">
                            <StackPanel Orientation="Horizontal" Margin="0,5">
                                <CheckBox x:Name="ChkChannel1" Content="Channel 1" IsChecked="True" VerticalAlignment="Center" Width="100" Checked="ChannelToggle_Changed" Unchecked="ChannelToggle_Changed"/>
                                <Slider x:Name="SldChannel1" Width="130" Minimum="0" Maximum="255" Value="255" VerticalAlignment="Center" ValueChanged="ChannelSlider_ValueChanged"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,5">
                                <CheckBox x:Name="ChkChannel2" Content="Channel 2" IsChecked="True" VerticalAlignment="Center" Width="100" Checked="ChannelToggle_Changed" Unchecked="ChannelToggle_Changed"/>
                                <Slider x:Name="SldChannel2" Width="130" Minimum="0" Maximum="255" Value="255" VerticalAlignment="Center" ValueChanged="ChannelSlider_ValueChanged"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,5">
                                <CheckBox x:Name="ChkChannel3" Content="Channel 3" IsChecked="True" VerticalAlignment="Center" Width="100" Checked="ChannelToggle_Changed" Unchecked="ChannelToggle_Changed"/>
                                <Slider x:Name="SldChannel3" Width="130" Minimum="0" Maximum="255" Value="255" VerticalAlignment="Center" ValueChanged="ChannelSlider_ValueChanged"/>
                            </StackPanel>
                            <StackPanel x:Name="Channel4Panel" Orientation="Horizontal" Margin="0,5" Visibility="Collapsed">
                                <CheckBox x:Name="ChkChannel4" Content="Channel 4" IsChecked="True" VerticalAlignment="Center" Width="100" Checked="ChannelToggle_Changed" Unchecked="ChannelToggle_Changed"/>
                                <Slider x:Name="SldChannel4" Width="130" Minimum="0" Maximum="100" Value="100" VerticalAlignment="Center" ValueChanged="ChannelSlider_ValueChanged"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Color Quantization" Margin="0,0,0,15" Padding="5">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Color Count:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBox x:Name="TxtColorCount" Width="50" Text="4" VerticalAlignment="Center" TextAlignment="Center"/>
                            <Button Content="Apply" Width="70" Margin="10,0,0,0" Click="ApplyQuantization_Click"/>
                        </StackPanel>
                    </GroupBox>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                        <Button Content="Reset" Width="100" Height="30" Margin="0,0,10,0" Background="#FFDDDD" Click="ResetButton_Click"/>
                        <Button Content="Save Image" Width="100" Height="30" Background="#DDFFDD" Click="SaveButton_Click"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>